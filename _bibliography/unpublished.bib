@phdthesis{babkinmsc,
  abbr = {MSc},
  abstract={В работе рассматривается задача автоматического поиска архитектур моделей типа Mixture-of-Experts (MoE). Предлагается метод поиска архитектуры, учитывающий кластерную структуру данных. Проведено экспериментальное исследование на задачах компьютерного зрения. Полученные результаты показывают, что предложенный подход обеспечивает более высокую точность и вычислительную эффективность по сравнению с базовыми архитектурами MoE, обученными на тех же наборах данных.},
abstract_en={The Mixture-of-Experts (MoE) layer, a sparsely activated neural architecture controlled by a routing mechanism, has recently achieved remarkable success across large-scale deep learning tasks. In parallel, Neural Architecture Search (NAS) has emerged as a powerful methodology for automatically discovering high-performing neural network. However, the application of NAS methods to MoE architectures remains an underexplored research area. In this work, we propose an architecture search framework for MoE models, which explicitly leverages the underlying cluster structure of the data. We evaluate the proposed approach on computer vision benchmarks and demonstrate that it outperforms baseline MoE architectures trained on the same datasets in terms of accuracy and computational efficiency.},
  author_en= {Petr Babkin},
  author       = {Бабкин Петр},   
  title_en = {Clustering structure aware mixture of experts architecture search, IS IDA}, 
  title        = {Поиск архитектуры модели смеси экспертов с учётом кластерной структуры данных, диплом магистра, ИС ИАД},
  note_en = {Scientific adviser:  Oleg Bakhteev, PhD},
  note ={Научный руководитель: к.ф.-м.н. Бахтеев О.Ю.},
  pdf={https://github.com/intsystems/nas-for-moe/blob/master/paper/src_diploma/main.pdf},
  year         = 2026,
}

@phdthesis{nikitinamsc,
  abbr = {MSc},
abstract = {В работе исследуется взаимосвязь между параметрами моделей автокодировщиков и статистическими свойствами данных, на которых они обучались. Под автокодировщиками понимаются модели с архитектурой кодировщик декодировщик, обучаемые восстанавливать входные данные через сжатое латентное представление. Вводится предположение, что спектральные характеристики параметров модели могут рассматриваться как плотное векторное представление соответствующей выборки. Для проверки этой гипотезы проводится теоретическое и экспериментальное исследование, в котором формируется векторное представление на основе спектральных характеристик матриц параметров автокодировщика. Теоретический анализ показывает, что сингулярные числа матриц параметров моделей связаны с собственными значениями ковариационной матрицы обучающих данных, что обеспечивает передачу информации между пространством данных и пространством параметров. Экспериментальные результаты на наборах CIFAR-10 и FashionMNIST подтверждают, что полученные векторные представления позволяют с высокой точностью различать модели, обученные на различных подмножествах данных, без привлечения сложных алгоритмов формирования векторов и использования исходных выборок. Эти результаты свидетельствуют о том, что спектральные характеристики параметров обученных автокодировщиков могут рассматриваться как представления выборок.},
abstract_en = {This paper examines the relationship between the parameters of autoencoder models and the statistical properties of the data on which they are trained. Autoencoders are defined as models with an encoder-decoder architecture, trained to reconstruct input data through a compressed latent representation. It is proposed that the model parameters can be viewed as a dense vector representation of the corresponding sample. To test this hypothesis, a theoretical and experimental study is conducted in which a vector representation is formed based on the spectral characteristics of the autoencoder parameter matrices. Theoretical analysis shows that the singular values of the model parameter matrices are related to the eigenvalues of the covariance matrix of the training data, ensuring the transfer of information between the data space and the parameter space. Experimental results on the CIFAR-10 and FashionMNIST datasets confirm that the resulting vector representations allow for a high degree of accuracy in distinguishing between models trained on different data subsets, without resorting to complex vector generation algorithms or using the original samples. These results suggest that the parameters of trained autoencoders can be viewed as sample representations.},
  author_en= {Maria Nikitina},
  author       = {Никитина Мария},   
  title = {Спектральные характеристики параметров атокодировщика как векторное представление данных},
title_en = {Spectral characteristics of autoencoder parameters as a vector representation of data},
  note_en = {Scientific adviser:  Oleg Bakhteev, PhD, scientific consultant: Anton Bishuk},
  note ={Научный руководитель: к.ф.-м.н. Бахтеев О.Ю., научный консультант: Бишук А. Ю.},
  html={https://github.com/intsystems/Vector-space-of-generative-models/tree/master/code},
  year         = 2026,
}

@unpublished{STIMO,
abbr = {pre-print},
abstract={A cervical spinal cord injury disrupts the signals between the brain and the region of the spinal cord that coordinates arm and hand movements, causing paralysis. Here, we engineered a chronically implanted and durable Digital Bridge that reestablishes communication between the brain and cervical spinal cord. This technology consists of a brain implant to record electrocorticography from the sensorimotor cortex, and a neurostimulation platform to deliver epidural electrical stimulation over the entire cervical spinal cord unilaterally. We implanted this Digital Bridge in three individuals with chronic incomplete tetraplegia. We configured a library of stimulation patterns that supported gradual control over various elementary movements of the arm and hand. A decoding pipeline incorporating a foundation model of human brain activity predicted up to 8 motor states with high accuracy. In turn, linking decoding predictions to the modulation of stimulation patterns targeting the preprogrammed elementary movements enabled the three participants to perform functional tasks with their otherwise paralyzed arm and hand. The Digital Bridge has remained stable for more than one year, and has been compatible with long-term stability and safety. While additional technological developments and clinical validations in a diverse patient population are required, these results establish essential concepts to enable arm and hand movements in humans living with chronic tetraplegia.},
author =  {Courtine, Grégoire et al.},
author_en = {Grégoire Courtine et al.},
title = "An Implantable Digital Bridge Enables Arm And Hand Movements After Tetraplegia",
html={https://infoscience.epfl.ch/entities/publication/4fc41eb5-3aca-4829-8bda-f7854e967eeb},
year={2026}
}

@phdthesis{denisovmsc,
  abbr = {MSc},
  abstract={Работа посвящена задаче идентификации источника загрязнения воздуха
по показаниям сети из небольшого числа датчиков с шумом. Рассматривается
вероятностная модель, в которой координаты источника, момент начала
и длительность выброса оцениваются совместно. Интенсивность выброса
маргинализуется аналитически с учётом физического ограничения
I0 >= 0 при усечённом нормальном априорном распределении. Предложены две параметризации профиля интенсивности: прямоугольный
импульс и гауссов процесс. Для последнего выведены явные формулы
апостериорного среднего и ковариации, допускающие маргинализацию
по неопределённости положения источника через закон полной дисперсии.
Байесовский вывод в пространстве параметров выполняется
алгоритмом AMIS, адаптивно уточняющим факторизованное предложенное распределение
в виде смеси гауссиан. Метод протестирован на синтетическом московском датасете при различных
степенях временного огрубления наблюдений (от исходного разрешения
до усреднения по 18 шагам). Медианная ошибка локализации источника
составила 4,9 км для модели с прямоугольным профилем и 5,9~км
для модели на основе гауссова процесса. Модель с гауссовым процессом
демонстрирует существенно меньшую апостериорную неопределённость
в пространстве координат: медианное значение σ_q составило
4,3 км против 10,5 км у модели с прямоугольным профилем,
что указывает на более концентрированный posterior при сопоставимой
точности MAP-оценки. Дополнительно метод апробирован на данных аварии на АЭС Фукусима-1
(2011), где при суточной дискретизации наблюдений локализация источника в пределах территории Японии.},
abstract_en={This work addresses the problem of identifying an air pollution source from measurements obtained by a small network of noisy sensors. We consider a probabilistic model in which the source coordinates, the start time, and the duration of the release are estimated jointly. The emission intensity is marginalized analytically under the physical constraint I0>=0 using a truncated normal prior. Two parametrizations of the intensity profile are proposed: a rectangular pulse and a Gaussian process. For the latter, explicit formulas for the posterior mean and covariance are derived, allowing marginalization over the uncertainty in the source location via the law of total variance. Bayesian inference in the parameter space is performed using the AMIS algorithm, which adaptively refines a factorized proposal distribution represented as a Gaussian mixture. The method is tested on a synthetic Moscow dataset under various degrees of temporal aggregation of observations (from the original resolution up to averaging over 18 time steps). The median source localization error is 4.9 km for the rectangular-profile model and 5.9 km for the Gaussian-process model. The Gaussian-process model exhibits substantially lower posterior uncertainty in the coordinate space: the median value of σ_q​ is 4.3 km, compared to 10.5 km for the rectangular-profile model, indicating a more concentrated posterior for comparable MAP estimation accuracy. Additionally, the method is applied to data from the Fukushima Daiichi nuclear accident (2011), where, with daily observation aggregation, the source is localized within the territory of Japan.},
  author_en= {Jacob Denisov},
  author       = {Денисов Яков},   
  title_en = {Air pollution source identification using noisy sensors, Master thesis at School of Data Analysis}, 
  title        = {Идентификация источника загрязнения воздуха по датчикам с шумом, диплом магистра, ШАД},
  note_en = {Scientific adviser: prof. Evgeny Burnaev, DSc. Scientific consultant: Oleg Bakhteev, PhD},
  note ={Научный руководитель: д.ф.-м.н. проф. Бурнаев Е.В., научный консультант: к.ф.-м.н. Бахтеев О.Ю.},
  year         = 2026,
}

